RewriteEngine On    # Turn on the rewriting engine

# HTTPS redirect - uncomment for production
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

RewriteCond %{THE_REQUEST} \s/+index\.php[\s?] [NC]
RewriteRule ^index\.php$ / [R=301,NC,L]

RewriteRule ^home/?$ / [R=301,NC,L]

RewriteRule ^sitemap\.xml$ sitemap.php [NC,L]

RewriteRule    ^careers\.php$    careers    [R=301,NC,L]
RewriteRule    ^about\.php$    about    [R=301,NC,L]
RewriteRule    ^services\.php$    services    [R=301,NC,L]
RewriteRule    ^contact\.php$    contact    [R=301,NC,L]
RewriteRule    ^portfolio\.php$    portfolio    [R=301,NC,L]
RewriteRule    ^blog\.php$    blog    [R=301,NC,L]
RewriteRule    ^privacy\.php$    privacy    [R=301,NC,L]
RewriteRule    ^terms\.php$    terms    [R=301,NC,L]
RewriteRule    ^cookie\.php$    cookie    [R=301,NC,L]

RewriteRule    ^home/?$    index.php    [NC,L]
RewriteRule    ^about/?$    about.php    [NC,L] 
RewriteRule    ^services/?$    services.php    [NC,L]
RewriteRule    ^contact/?$    contact.php    [NC,L]
RewriteRule    ^portfolio/?$    portfolio.php    [NC,L]
RewriteRule    ^blog/?$    blog.php    [NC,L]
RewriteRule    ^careers/?$    careers.php    [NC,L]
RewriteRule    ^pricing/?$    pricing.php    [NC,L]
RewriteRule    ^jobdetail/([A-Za-z0-9-]+)/?$    jobdetail.php?id=$1    [NC,L]
RewriteRule    ^privacy/?$    privacy.php    [NC,L]
RewriteRule    ^terms/?$    terms.php    [NC,L]
RewriteRule    ^cookie/?$    cookie.php    [NC,L]
RewriteRule    ^refer/?$     refer.php     [NC,L]
